<style>
/* backup: if it's a fixed overlay layer */
body.popup-killed,
html.popup-killed {
  overflow: auto !important;
}
</style>

<script>
(function () {
  // ? Popup ke unique keywords (site ke popup me yahi aa raha hai)
  const KEYWORDS = [
    "WINTER SMILE PACKAGES",
    "Zoom Advance Whitening Package",
    "Affordable Implants",
    "Wisdom Tooth Removal",
    "Valid from 23rd Dec to 10th Jan"
  ];

  function containsKeyword(text) {
    if (!text) return false;
    text = text.replace(/\s+/g, ' ').trim().toLowerCase();
    return KEYWORDS.some(k => text.includes(k.toLowerCase()));
  }

  function isOverlayLike(el) {
    if (!el || el === document.body || el === document.documentElement) return false;
    const s = window.getComputedStyle(el);
    const pos = s.position;
    const z = parseInt(s.zIndex || "0", 10);
    // typical overlay: fixed/absolute + high z-index + large size
    const rect = el.getBoundingClientRect();
    const bigEnough = rect.width > window.innerWidth * 0.6 && rect.height > window.innerHeight * 0.3;
    return (pos === "fixed" || pos === "absolute") && (z >= 10 || s.zIndex === "auto") && bigEnough;
  }

  function killPopupOnce() {
    const all = document.querySelectorAll("body *");
    for (const el of all) {
      // text-based match
      const t = (el.innerText || "").slice(0, 2000);
      if (!containsKeyword(t)) continue;

      // climb up: find nearest overlay-like parent and remove it
      let cur = el;
      let removed = false;
      for (let i = 0; i < 12 && cur; i++) {
        if (isOverlayLike(cur)) {
          cur.remove();
          removed = true;
          break;
        }
        cur = cur.parentElement;
      }

      // if overlay parent not found, remove the matched block itself
      if (!removed) el.remove();

      // remove scroll-lock just in case
      document.documentElement.style.overflow = "auto";
      document.body.style.overflow = "auto";
      document.body.classList.remove("modal-open");
      document.documentElement.classList.add("popup-killed");
      document.body.classList.add("popup-killed");
      return true; // killed
    }
    return false;
  }

  // run immediately + after load
  killPopupOnce();
  window.addEventListener("load", killPopupOnce);

  // keep killing if re-injected
  const obs = new MutationObserver(() => killPopupOnce());
  obs.observe(document.documentElement, { childList: true, subtree: true });

  // extra safety
  setInterval(killPopupOnce, 800);
})();
</script>


